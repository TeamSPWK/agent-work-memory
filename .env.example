# Agent Work Memory — 환경 변수 예시
# 실제 값은 .env.local에 (git 추적 안 됨, .gitignore 확인)
# 민감도 높은 키는 1Password/Bitwarden 등 secret manager 사용 권장.

# ─────────────────────────────────────────────────────────────
# Supabase Tokyo (ap-northeast-1) — M1.1
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# 서버 전용. 절대 클라이언트(브라우저·CLI)에 노출 X.
SUPABASE_SERVICE_ROLE_KEY=

# 로컬 dev DB (supabase start로 시작 — Docker 필요)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_LOCAL_URL=http://127.0.0.1:54321

# ─────────────────────────────────────────────────────────────
# Clerk — M1.2
# Application: agent-work-memory (production / development 분리)
# B2B Organizations 활성화 필요 (Dashboard → Organizations)
# JWT template: "supabase" — workspace_id claim 주입
# ─────────────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
# Webhook signing secret (Clerk webhook → Fly.io)
CLERK_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# Fly.io — M1.3
# Deploy: fly deploy --remote-only
# Region: nrt (도쿄, Supabase Tokyo와 same-region)
# ─────────────────────────────────────────────────────────────
FLY_API_TOKEN=
FLY_APP_NAME=agent-work-memory

# ─────────────────────────────────────────────────────────────
# Toss Payments — M4 (참고만, M4까지 미사용)
# ─────────────────────────────────────────────────────────────
# TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=
# TOSS_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# Sentry / Logtail (운영 모니터링)
# ─────────────────────────────────────────────────────────────
# SENTRY_DSN=
# LOGTAIL_TOKEN=

# ─────────────────────────────────────────────────────────────
# 환경 식별 — production / staging / development
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development
