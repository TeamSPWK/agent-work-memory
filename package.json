{
  "name": "agent-work-memory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "awm": "./bin/awm.mjs"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "cli": "node ./bin/awm.mjs",
    "local": "npm run mvp",
    "mvp": "npm run build && node ./bin/awm.mjs ingest --limit 30 && node ./bin/awm.mjs serve --port 5173",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.11"
  }
}
